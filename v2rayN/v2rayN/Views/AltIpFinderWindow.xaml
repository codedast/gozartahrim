<base:WindowBase
    x:Class="v2rayN.Views.AltIpFinderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:v2rayN.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:reactiveui="http://reactiveui.net"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    Title="{x:Static resx:ResUI.AltIpFinderTitle}"
    Width="640"
    Height="680"
    x:TypeArguments="vms:AltIpFinderViewModel"
    ShowInTaskbar="False"
    Style="{StaticResource WindowGlobal}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <DockPanel Margin="{StaticResource Margin8}">
        <StackPanel
            Margin="{StaticResource Margin4}"
            HorizontalAlignment="Center"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                x:Name="btnStart"
                Width="120"
                Content="{x:Static resx:ResUI.AltIpFinderStart}"
                Style="{StaticResource DefButton}" />
            <Button
                x:Name="btnCancel"
                Width="100"
                Margin="{StaticResource MarginLeftRight8}"
                Content="{x:Static resx:ResUI.AltIpFinderCancel}"
                Style="{StaticResource DefButton}" />
            <Button
                x:Name="btnClose"
                Width="100"
                Content="{x:Static resx:ResUI.TbCancel}"
                Style="{StaticResource DefButton}" />
        </StackPanel>

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="{StaticResource Margin4}"
                VerticalAlignment="Center"
                Text="{x:Static resx:ResUI.AltIpFinderFofaApiKey}" />
            <TextBox
                x:Name="txtFofaApiKey"
                Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Margin="{StaticResource Margin4}"
                materialDesign:HintAssist.Hint="{x:Static resx:ResUI.AltIpFinderFofaApiKeyTip}"
                Style="{StaticResource MyOutlinedTextBox}" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Margin="{StaticResource Margin4}"
                VerticalAlignment="Center"
                Text="Preset:" />
            <ComboBox
                x:Name="cmbPreset"
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Margin="{StaticResource Margin4}"
                DisplayMemberPath="DisplayName"
                Style="{StaticResource DefComboBox}" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Margin="{StaticResource Margin4}"
                VerticalAlignment="Center"
                Text="Query (FOFA syntax):" />
            <TextBox
                x:Name="txtQuery"
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Height="60"
                Margin="{StaticResource Margin4}"
                AcceptsReturn="True"
                Style="{StaticResource MyOutlinedTextBox}"
                TextWrapping="Wrap" />

            <TextBlock
                Grid.Row="4"
                Grid.Column="0"
                Margin="{StaticResource Margin4}"
                VerticalAlignment="Center"
                Text="{x:Static resx:ResUI.AltIpFinderSampleCount}" />
            <TextBox
                x:Name="txtSampleCount"
                Grid.Row="4"
                Grid.Column="1"
                Margin="{StaticResource Margin4}"
                Style="{StaticResource MyOutlinedTextBox}" />

            <TextBlock
                Grid.Row="4"
                Grid.Column="2"
                Margin="{StaticResource Margin4}"
                VerticalAlignment="Center"
                Text="{x:Static resx:ResUI.AltIpFinderConcurrency}" />
            <TextBox
                x:Name="txtConcurrency"
                Grid.Row="4"
                Grid.Column="3"
                Margin="{StaticResource Margin4}"
                Style="{StaticResource MyOutlinedTextBox}" />

            <TextBlock
                x:Name="txtProgress"
                Grid.Row="5"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Margin="{StaticResource Margin4}"
                VerticalAlignment="Center" />
        </Grid>

        <ListBox
            x:Name="lstResults"
            Margin="{StaticResource Margin4}"
            FontSize="{DynamicResource StdFontSize}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="140" Text="{Binding Ip}" />
                        <TextBlock Width="100" Text="{Binding Source}" />
                        <TextBlock Width="80" Text="{Binding TcpOk}" />
                        <TextBlock Width="80" Text="{Binding TlsOk}" />
                        <TextBlock Width="100" Text="{Binding LatencyMs}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</base:WindowBase>
